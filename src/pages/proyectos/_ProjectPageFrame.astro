---
import { IconArrowLeft, IconExternalLink, IconMail } from "@tabler/icons-react";
import ButtonLink from "../../components/ButtonLink.astro";
import ProjectDetailSection from "../../components/ProjectDetailSection.astro";
import ProjectDetailsNav from "../../components/ProjectDetailsNav.tsx";
import ProjectIcon from "../../components/ProjectIcon";
import ProjectTools from "../../components/ProjectTools.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import Layout from "../../layouts/Layout.astro";
import type { Project } from "../../data/projects";
import Carousel from "../../components/Carousel.tsx";
import { site } from "../../data/site";

type Props = {
  project: Project;
};

const { project } = Astro.props;
const intro = project.intro ?? project.summary;
const eyebrow = "font-mono text-xs uppercase tracking-[0.08em] text-[#5faf7b]";
const formatNumber = (index: number) => index.toString().padStart(2, "0");
const navItems = project.details.map((detail, index) => ({
  id: detail.id,
  number: formatNumber(index),
  label: detail.eyebrow,
}));
const projectPath = `/proyectos/${project.slug}/`;
const projectUrl = new URL(projectPath, site.url).toString();
const projectImage = project.images?.[0]?.src;
const projectDescription = project.intro ?? project.summary;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    name: project.title,
    headline: project.title,
    description: projectDescription,
    url: projectUrl,
    image: projectImage
      ? new URL(projectImage, site.url).toString()
      : undefined,
    author: {
      "@type": "Person",
      name: site.fullName,
      alternateName: site.name,
      url: site.url,
    },
    keywords: project.stack.join(", "),
    inLanguage: site.language,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Inicio",
        item: site.url,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Proyectos",
        item: new URL("/#proyectos", site.url).toString(),
      },
      {
        "@type": "ListItem",
        position: 3,
        name: project.title,
        item: projectUrl,
      },
    ],
  },
];
---

<Layout
  title={`${project.title} | MauricioDMO`}
  description={projectDescription}
  pathname={projectPath}
  image={projectImage}
  preloadImages={projectImage ? [projectImage] : []}
  type="article"
  structuredData={structuredData}
>
  <SiteHeader variant="project" />

  <main>
    <section class="mx-auto w-[min(calc(100%-2rem),1120px)] py-20 md:py-24">
      <div
        class="grid gap-7 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-start lg:gap-16"
      >
        <div>
          <div class="flex items-center gap-3">
            <ProjectIcon
              icon={project.icon}
              className="text-[#5faf7b]"
              size={38}
              stroke={1.7}
              aria-hidden="true"
            />
            <p class={eyebrow}>{project.eyebrow}</p>
          </div>
          <h1
            class="mt-6 max-w-225 text-[clamp(3rem,8vw,7rem)] leading-[0.92] tracking-[-0.08em] text-[#e8eee9]"
            transition:name={`project-title-${project.slug}`}
          >
            {project.title}
          </h1>
          <p
            class="mt-7 max-w-190 text-[clamp(1.08rem,1.8vw,1.35rem)] leading-[1.65] text-[#c4d0c8]"
          >
            {intro}
          </p>
        </div>

        <div
          class="flex flex-wrap gap-3 justify-center items-center lg:flex-col h-full lg:items-start lg:pt-1"
        >
          <ButtonLink href="/#proyectos" class="lg:mx-auto">
            <IconArrowLeft size={18} stroke={1.8} aria-hidden="true" />
            Volver a proyectos
          </ButtonLink>
          {
            project.url ? (
              <ButtonLink href={project.url} target="_blank" class="lg:mx-auto">
                <IconExternalLink size={18} stroke={1.8} aria-hidden="true" />
                Ver proyecto en vivo
              </ButtonLink>
            ) : null
          }
          <ButtonLink
            href="mailto:mauriciodmoprogrammer@gmail.com"
            variant="primary"
          >
            <IconMail size={18} stroke={1.8} aria-hidden="true" />
            Hablemos de un proyecto
          </ButtonLink>
        </div>
      </div>

      <div
        class="mt-8 grid gap-8 lg:grid-cols-[260px_minmax(0,1fr)] lg:items-start lg:gap-12"
      >
        <div class="grid gap-7">
          <ProjectTools
            stack={project.stack}
            label={`Stack de ${project.title}`}
          />
        </div>

        <Carousel
          images={project.images || []}
          infinity={true}
          transitionName={`project-image-${project.slug}`}
          client:load
        />
      </div>
    </section>

    <section class="border-t border-[#26352c]/60 pb-20">
      <div
        class="sticky top-18 z-10 bg-[#0d1210]/90 pt-9 backdrop-blur-xl md:hidden"
      >
        <div class="mx-auto w-[min(calc(100%-2rem),1120px)]">
          <ProjectDetailsNav items={navItems} client:load />
        </div>
      </div>

      <div
        class="mx-auto grid w-[min(calc(100%-2rem),1120px)] gap-10 pt-14 md:grid-cols-[190px_minmax(0,760px)] md:gap-14 lg:grid-cols-[210px_minmax(0,820px)]"
      >
        <aside class="sticky top-28 hidden self-start md:block">
          <ProjectDetailsNav items={navItems} client:load />
        </aside>

        <div>
          {
            project.details.map((detail, index) => {
              return (
                <ProjectDetailSection
                  id={detail.id}
                  number={formatNumber(index)}
                  eyebrow={detail.eyebrow}
                  title={detail.title}
                  icon={detail.icon}
                >
                  {detail.content.map((block) =>
                    "list" in block ? (
                      <ul class="mt-5 grid gap-3 p-0 first:mt-0">
                        {block.list.map((item) => (
                          <li class="list-none border-l border-[#5faf7b]/40 pl-4 leading-relaxed">
                            {item}
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p>{block.text}</p>
                    ),
                  )}
                </ProjectDetailSection>
              );
            })
          }
        </div>
      </div>
    </section>

    <section class="border-t border-[#26352c]/60 py-18">
      <div
        class="mx-auto grid w-[min(calc(100%-2rem),1120px)] gap-7 md:grid-cols-[minmax(0,1fr)_auto] md:items-end md:gap-10"
      >
        <div>
          <p class={eyebrow}>Trabajemos juntos</p>
          <h2
            class="mt-4 max-w-180 text-[clamp(2.2rem,5vw,4.8rem)] leading-[0.95] tracking-[-0.07em] text-[#e8eee9]"
          >
            Si tu proyecto necesita avanzar con criterio, hablemos.
          </h2>
          <p class="mt-5 max-w-160 text-lg leading-[1.7] text-[#c4d0c8]">
            Puedo ayudarte a convertir una idea, proceso interno o problema
            operativo en una herramienta clara, rápida y mantenible.
          </p>
        </div>

        <div class="h-full flex items-center justify-center">
          <ButtonLink
            href="mailto:mauriciodmoprogrammer@gmail.com"
            variant="primary"
          >
            <IconMail size={18} stroke={1.8} aria-hidden="true" />
            Empecemos una conversación
          </ButtonLink>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter label={project.title} homeLink />
</Layout>
