---
import {
  IconArrowUpRight,
  IconBolt,
  IconBrain,
  IconCode,
  IconShieldCheck,
  IconTargetArrow,
  IconUserCheck,
} from '@tabler/icons-react';
import { getProjectBySlug } from '../../data/projects';
import ProjectPageFrame from './_ProjectPageFrame.astro';

const project = getProjectBySlug('sistema-rma-garantias');
const eyebrow = 'font-mono text-xs uppercase tracking-[0.08em] text-[#5faf7b]';
const card = 'rounded-[6px] border border-[#26352c] bg-[#16211b]/75 p-5';
---

<ProjectPageFrame project={project} icon={IconShieldCheck} intro="Sistema para que cada garantia tenga contexto, estado y continuidad durante todo el ciclo de revision.">
  <Fragment slot="details">
    <article class={card}>
      <IconTargetArrow className="mb-4 text-[#5faf7b]" size={24} stroke={1.7} aria-hidden="true" />
      <p class={eyebrow}>01 · Perdida de seguimiento</p>
      <p class="mt-3 leading-relaxed text-[#9baaa0]">{project.problem}</p>
    </article>

    <article class={card}>
      <IconBolt className="mb-4 text-[#5faf7b]" size={24} stroke={1.7} aria-hidden="true" />
      <p class={eyebrow}>02 · Flujo rastreable</p>
      <p class="mt-3 leading-relaxed text-[#9baaa0]">{project.solution}</p>
    </article>

    <article class={card}>
      <IconCode className="mb-4 text-[#5faf7b]" size={24} stroke={1.7} aria-hidden="true" />
      <p class={eyebrow}>03 · Piezas del sistema</p>
      <ul class="mt-3 grid gap-2.5 p-0">
        {project.features.map((feature) => <li class="list-none leading-relaxed text-[#9baaa0] before:mr-2 before:text-[#5faf7b] before:content-['+']">{feature}</li>)}
      </ul>
    </article>

    <article class={card}>
      <IconBrain className="mb-4 text-[#5faf7b]" size={24} stroke={1.7} aria-hidden="true" />
      <p class={eyebrow}>04 · Experiencia de seguimiento</p>
      <p class="mt-3 leading-relaxed text-[#9baaa0]">{project.ux}</p>
    </article>

    <article class={card}>
      <IconUserCheck className="mb-4 text-[#5faf7b]" size={24} stroke={1.7} aria-hidden="true" />
      <p class={eyebrow}>05 · Mi rol</p>
      <p class="mt-3 leading-relaxed text-[#9baaa0]">{project.role}</p>
    </article>

    <article class={card}>
      <IconArrowUpRight className="mb-4 text-[#5faf7b]" size={24} stroke={1.7} aria-hidden="true" />
      <p class={eyebrow}>06 · Aprendizaje del proceso</p>
      <p class="mt-3 leading-relaxed text-[#9baaa0]">{project.learnings}</p>
    </article>
  </Fragment>
</ProjectPageFrame>
