---
type Props = {
  index: number;
  title: string;
  text: string;
  Icon: any;
  class?: string;
  revealDelay?: string;
};

type RevealStyle = {
  '--reveal-delay': string;
};

const { index, title, text, Icon, class: className, revealDelay = '0ms' } = Astro.props;
const revealStyle: RevealStyle = { '--reveal-delay': revealDelay };
---

<article
  class:list={["rounded-[6px] border border-[#26352c] bg-[#16211b]/75 p-6", className]}
  data-process-reveal
  style={revealStyle}
>
  <div class="flex items-center justify-between gap-4">
    <span class="font-mono text-xs text-[#5faf7b]">{String(index + 1).padStart(2, '0')}</span>
    <Icon className="text-[#5faf7b]" size={22} stroke={1.7} aria-hidden="true" />
  </div>
  <h3 class="mt-4 tracking-[-0.04em] text-[#e8eee9]">{title}</h3>
  <p class="mt-3 leading-relaxed text-[#9baaa0]">{text}</p>
</article>
