---
import {
  IconArrowUpRight,
  IconBrandGithub,
  IconBrandLinkedin,
  IconMail,
} from "@tabler/icons-react";
import ButtonLink from "../../components/ButtonLink.astro";
import { site } from "../../data/site";
import HeroSignalCard from "./components/HeroSignalCard.astro";

const focusPoints = [
  "Landings y sitios web claros",
  "Experiencias web cuidadas",
  "Sistemas internos mantenibles",
];
---

<section
  class="mx-auto grid w-[min(calc(100%-2rem),1120px)] items-center gap-8 py-16 md:grid-cols-[1.12fr_0.88fr] md:py-20 lg:gap-12"
>
  <div class="max-w-3xl">
    <p class="font-mono text-xs uppercase tracking-[0.08em] text-[#5faf7b]">
      Desarrollador web · Full-stack · UX útil
    </p>
    <h1
      class="mt-5 max-w-[760px] text-[clamp(2.7rem,6vw,5.4rem)] leading-[0.93] tracking-[-0.075em] text-[#e8eee9]"
      transition:name="page-title"
    >
      Webs claras y sistemas que ordenan operaciones.
    </h1>
    <p
      class="mt-6 max-w-[660px] text-[clamp(1.02rem,1.5vw,1.2rem)] leading-[1.65] text-[#9baaa0]"
    >
      Soy MauricioDMO. Diseño y desarrollo landings, sitios web y herramientas
      internas con foco en claridad, buen rendimiento y experiencias fáciles de
      usar para personas reales.
    </p>
    <ul
      class="mt-6 grid gap-2 text-sm text-[#d5ded8] sm:grid-cols-3"
      aria-label="Áreas de trabajo principales"
    >
      {
        focusPoints.map((point) => (
          <li class="flex items-center gap-2 rounded border border-[#26352c]/80 bg-[#121d17]/70 px-3 py-2">
            <span
              class="h-1.5 w-1.5 shrink-0 rounded-full bg-[#5faf7b]"
              aria-hidden="true"
            />
            {point}
          </li>
        ))
      }
    </ul>
    <div class="mt-7 flex flex-wrap gap-3">
      <ButtonLink href="#proyectos" variant="primary">
        Ver proyectos reales
        <IconArrowUpRight size={18} stroke={1.8} aria-hidden="true" />
      </ButtonLink>
      <ButtonLink href="mailto:mauriciodmoprogrammer@gmail.com">
        <IconMail size={18} stroke={1.8} aria-hidden="true" />
        Hablemos de tu proyecto
      </ButtonLink>
    </div>
    <div class="mt-5 flex flex-wrap items-center gap-3 text-sm text-[#9baaa0]">
      <span class="font-mono text-xs uppercase tracking-[0.08em] text-[#6f8175]">
        También en
      </span>
      <a
        class="inline-flex items-center gap-2 rounded-full border border-[#26352c] bg-[#121d17]/70 px-3 py-2 text-[#d5ded8] no-underline transition hover:-translate-y-0.5 hover:border-[#5faf7b]/70 hover:text-[#e8eee9]"
        href={site.github}
        target="_blank"
        rel="noreferrer"
      >
        <IconBrandGithub size={18} stroke={1.8} aria-hidden="true" />
        GitHub
      </a>
      <a
        class="inline-flex items-center gap-2 rounded-full border border-[#26352c] bg-[#121d17]/70 px-3 py-2 text-[#d5ded8] no-underline transition hover:-translate-y-0.5 hover:border-[#5faf7b]/70 hover:text-[#e8eee9]"
        href={site.linkedin}
        target="_blank"
        rel="noreferrer"
      >
        <IconBrandLinkedin size={18} stroke={1.8} aria-hidden="true" />
        LinkedIn
      </a>
    </div>
  </div>

  <HeroSignalCard />
</section>
