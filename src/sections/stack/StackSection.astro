---
import {
  IconCode,
  IconDatabase,
  IconServer,
  IconSparkles,
  IconTool,
} from "@tabler/icons-react";
import SectionHeader from "../../components/SectionHeader.astro";
import TechPill from "../../components/TechPill.astro";
import StackCard from "./components/StackCard.astro";

type StackItem = [title: string, text: string, Icon: typeof IconCode];
type StackLogo = [name: string, src: string, href: string];

const stack: StackItem[] = [
  [
    "Frontend",
    "Interfaces con Next.js, Astro, React y Tailwind, cuidando estados, responsive, experiencia de usuario, accesibilidad y flujos que reduzcan fricción para usuarios operativos.",
    IconCode,
  ],
  [
    "Backend",
    "APIs con Node.js y Express, autenticación con JWT, reglas de negocio, validaciones e integraciones que conectan el sistema con servicios de terceros.",
    IconServer,
  ],
  [
    "Datos",
    "Modelado y consultas con PostgreSQL, Turso, Prisma, priorizando consistencia, trazabilidad y mantenimiento. Los datos son el corazón del sistema, no una parte olvidada.",
    IconDatabase,
  ],
  [
    "Operacion",
    "Despliegues, almacenamiento, Git, Linux, Bash, Docker y servicios cloud. La infraestructura es parte del sistema, no un extra, y la mantengo con el mismo cuidado que el resto del software.",
    IconTool,
  ],
  [
    "Proceso",
    "Elijo herramientas que ayuden a construir sistemas claros, rápidos y mantenles. No me caso con ninguna tecnología, sino que busco la mejor para cada proyecto y contexto.",
    IconSparkles,
  ],
];

const stackLogos: StackLogo[] = [
  ["Next.js", "/svg/nextjs_icon_dark.svg", "https://nextjs.org/"],
  ["Node.js", "/svg/nodejs.svg", "https://nodejs.org/"],
  ["Express.js", "/svg/expressjs_dark.svg", "https://expressjs.com/"],
  ["PostgreSQL", "/svg/postgresql.svg", "https://www.postgresql.org/"],
  ["Turso", "/svg/turso-dark.svg", "https://turso.tech/"],
  ["Astro", "/svg/astro-icon-dark.svg", "https://astro.build/"],
  ["React", "/svg/react_dark.svg", "https://react.dev/"],
  ["Tailwind CSS", "/svg/tailwindcss.svg", "https://tailwindcss.com/"],
  ["AWS", "/svg/aws_dark.svg", "https://aws.amazon.com/"],
  ["GitHub", "/svg/github_dark.svg", "https://github.com/"],
  ["Git", "/svg/git.svg", "https://git-scm.com/"],
  ["Docker", "/svg/docker.svg", "https://www.docker.com/"],
  ["Vercel", "/svg/vercel_dark.svg", "https://vercel.com/"],
  ["JWT", "/svg/jwt.svg", "https://jwt.io/"],
  ["Prisma", "/svg/prisma_dark.svg", "https://www.prisma.io/"],
  ["Vite", "/svg/vite.svg", "https://vite.dev/"],
  ["pnpm", "/svg/pnpm_dark.svg", "https://pnpm.io/"],
  ["OpenCode", "/svg/opencode-dark.svg", "https://opencode.ai/"],
  ["Obsidian", "/svg/obsidian.svg", "https://obsidian.md/"],
  ["Linux", "/svg/linux.svg", "https://www.linux.org/"],
  ["Bash", "/svg/bash_dark.svg", "https://www.gnu.org/software/bash/"],
  [
    "JavaScript",
    "/svg/javascript.svg",
    "https://developer.mozilla.org/en-US/docs/Web/JavaScript",
  ],
  ["TypeScript", "/svg/typescript.svg", "https://www.typescriptlang.org/"],
  [
    "HTML5",
    "/svg/html5.svg",
    "https://developer.mozilla.org/en-US/docs/Web/HTML",
  ],
];
---

<section class="border-t border-[#26352c]/60 py-18" id="stack">
  <div class="mx-auto w-[min(calc(100%-2rem),1120px)]">
    <SectionHeader
      eyebrow="Stack tecnico"
      title="Tecnología al servicio del proceso."
      description="Uso de herramientas modernas. La prioridad es elegir tecnología que ayude a construir sistemas claros, rápidos y mantenibles."
    />

    <div
      class="mb-8 flex flex-wrap gap-5 justify-center"
      aria-label="Tecnologías utilizadas"
    >
      {
        stackLogos.map(([name, src, href]) => (
          <TechPill name={name} src={src} href={href} />
        ))
      }
    </div>

    <div class="grid gap-3 md:grid-cols-6">
      {
        stack.map(([title, text, Icon], index) => (
          <StackCard
            title={title}
            text={text}
            Icon={Icon}
            offset={index === 3}
          />
        ))
      }
    </div>
  </div>
</section>
