---
type Props = {
  title: string;
  text: string;
  Icon: any;
  offset?: boolean;
};

const { title, text, Icon, offset = false } = Astro.props;
---

<article
  class={`rounded-md border border-[#26352c] bg-[#16211b]/75 p-5 md:col-span-2 ${offset ? "md:col-start-2" : ""}`}
>
  <Icon
    className="mb-4 text-[#5faf7b]"
    size={24}
    stroke={1.7}
    aria-hidden="true"
  />
  <p class="font-mono text-xs uppercase tracking-[0.08em] text-[#5faf7b]">
    {title}
  </p>
  <p class="mt-3 leading-relaxed text-[#9baaa0]">{text}</p>
</article>
