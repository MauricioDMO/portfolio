---
import { IconArrowUpRight, IconMail } from '@tabler/icons-react';
import ButtonLink from '../../components/ButtonLink.astro';
---

<section class="border-t border-[#26352c]/60 py-18" id="contacto">
  <div class="mx-auto grid w-[min(calc(100%-2rem),1120px)] gap-9 md:grid-cols-[0.8fr_1.2fr]">
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.08em] text-[#5faf7b]">Contacto</p>
      <h2 class="mt-4 text-[clamp(2rem,4vw,3.6rem)] leading-none tracking-[-0.06em] text-[#e8eee9]">Trabajemos juntos.</h2>
    </div>
    <div>
      <p class="text-lg leading-relaxed text-[#9baaa0]">
        Si necesitas ordenar un proceso, construir una herramienta interna o mejorar una experiencia
        web, conversemos con contexto y sin humo.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <ButtonLink href="mailto:hola@mauriciodmo.com" variant="primary">
          <IconMail size={18} stroke={1.8} aria-hidden="true" />
          Escribeme
        </ButtonLink>
        <ButtonLink href="#proyectos">
          Revisar proyectos
          <IconArrowUpRight size={18} stroke={1.8} aria-hidden="true" />
        </ButtonLink>
      </div>
    </div>
  </div>
</section>
