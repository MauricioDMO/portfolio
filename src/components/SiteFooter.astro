---
type Props = {
  label?: string;
  homeLink?: boolean;
};

const { label = 'MauricioDMO', homeLink = false } = Astro.props;
---

<footer class="border-t border-[#26352c]/60 py-10 text-[#9baaa0]">
  <div class="mx-auto flex w-[min(calc(100%-2rem),1120px)] justify-between gap-6 max-sm:flex-col">
    <span>{label}</span>
    {homeLink ? (
      <a class="transition-colors hover:text-[#e8eee9]" href="/">Volver al inicio</a>
    ) : (
      <span>Software practico para procesos reales.</span>
    )}
  </div>
</footer>
