---
type Props = {
  href: string;
  variant?: "primary" | "secondary";
  class?: string;
};

const { href, variant = "secondary", class: customClass } = Astro.props;

const base =
  "inline-flex min-h-11 items-center justify-center gap-2 rounded-[6px] border px-4 font-semibold text-[#e8eee9] no-underline transition hover:-translate-y-0.5";
const variants = {
  primary:
    "border-[#5faf7b]/55 bg-gradient-to-br from-[#1f5e3b] to-[#183a2a] hover:border-[#5faf7b]",
  secondary:
    "border-[#26352c] bg-[#16211b] hover:border-[#5faf7b]/70 hover:bg-[#18271f]",
};
---

<a class={`${base} ${variants[variant]} ${customClass || ""}`} href={href}>
  <slot />
</a>
