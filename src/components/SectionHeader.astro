---
type Props = {
  eyebrow: string;
  title: string;
  description: string;
};

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-8 grid gap-9 md:grid-cols-[0.8fr_1.2fr]">
  <div>
    <p class="font-mono text-xs uppercase tracking-[0.08em] text-[#5faf7b]">
      {eyebrow}
    </p>
    <h2
      class="mt-4 text-[clamp(2rem,4vw,3.6rem)] leading-none tracking-[-0.06em] text-[#e8eee9]"
    >
      {title}
    </h2>
  </div>
  <div class="flex flex-col justify-center">
    <p class="text-lg leading-relaxed text-[#9baaa0]">{description}</p>
  </div>
</div>
