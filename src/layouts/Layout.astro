---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "MauricioDMO | Software práctico para procesos reales",
  description = "Portafolio de MauricioDMO, Full-Stack Developer enfocado en sistemas internos, automatización y experiencias web útiles.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body class="text-pretty">
    <slot />
  </body>
</html>
